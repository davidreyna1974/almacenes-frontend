#!/bin/sh
BRANCH=$(git branch --show-current)
for protected in develop main; do
  if [ "$BRANCH" = "$protected" ]; then
    echo ""
    echo "  ✗ COMMIT BLOQUEADO"
    echo "  La branch '$BRANCH' está protegida — no acepta commits directos."
    echo ""
    echo "  Pasos correctos:"
    echo "    1. git checkout -b feature/<nombre>"
    echo "    2. Commitear en la nueva branch"
    echo "    3. git checkout $BRANCH && git merge --no-ff feature/<nombre>"
    echo ""
    exit 1
  fi
done
exit 0
